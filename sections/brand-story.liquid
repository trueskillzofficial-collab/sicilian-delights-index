{%- assign pg_chi = pages['chi-siamo'] -%}
{%- assign chi_url = section.settings.cta_link | default: pg_chi.url | default: '/pages/chi-siamo' -%}

<section class="section brand-story texture" aria-labelledby="story-title-{{ section.id }}">
  <div class="container">
    <div class="story-grid">

      <div class="story-text">
        <p class="eyebrow eyebrow-light">Chi siamo</p>
        <h2 class="section-title" id="story-title-{{ section.id }}">
          Da Ariano Irpino,<br>con l'anima<br>della Sicilia.
        </h2>
        <blockquote class="quote">
          Ogni morso è un viaggio. Da queste colline irpine, fin nel cuore dell'isola più bella del mondo.
        </blockquote>
        <p>
          Siamo nati dall'incontro di due anime forti: la tenacia dell'Irpinia e la dolcezza della Sicilia.
          Nel nostro laboratorio ad Ariano Irpino trasformiamo ricette tramandate da generazioni
          in dolci che viaggiano in tutta Italia.
        </p>
        <p>
          Ogni cannolo viene chiuso al momento della spedizione. Ogni cassata è realizzata con ricotta
          fresca di pecora. Ogni mandorla è selezionata una ad una. Non è solo pasticceria —
          è artigianalità che parla siciliano.
        </p>
        <a href="{{ chi_url }}" class="btn btn-ghost">La nostra storia</a>
      </div>

      <div class="story-photos" aria-hidden="true">
        <div class="story-photo">
          {% if section.settings.image1 != blank %}
            <img
              src="{{ section.settings.image1 | image_url: width: 700 }}"
              alt="{{ section.settings.image1.alt | default: 'Laboratorio artigianale Delizie Siciliane' | escape }}"
              loading="lazy">
          {% else %}
            <div class="card-img-placeholder" style="height:100%;display:flex;align-items:center;justify-content:center">Kit Cannoli</div>
          {% endif %}
        </div>
        <div class="story-photo">
          {% if section.settings.image2 != blank %}
            <img
              src="{{ section.settings.image2 | image_url: width: 700 }}"
              alt="{{ section.settings.image2.alt | default: 'Cannoli artigianali siciliani' | escape }}"
              loading="lazy">
          {% else %}
            <div class="card-img-placeholder" style="height:100%;display:flex;align-items:center;justify-content:center">Cannoli</div>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

<div class="inter-wave wave-reverse" aria-hidden="true" style="background:var(--color-rosso);margin-top:-30px;position:relative;z-index:5;">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2880 64" preserveAspectRatio="none">
    <path d="M0 32 C240 0, 480 64, 720 32 C960 0, 1200 64, 1440 32 C1680 0, 1920 64, 2160 32 C2400 0, 2640 64, 2880 32 L2880 64 L0 64 Z" fill="{{ settings.color_crema | default: '#E8E2CD' }}"/>
  </svg>
</div>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image1",
      "label": "Foto sinistra (alto)"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "Foto destra (basso)"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link «La nostra storia»"
    }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
